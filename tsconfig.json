{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"rootDir": "./",
		"outDir": "./dist/",
		"strict": true,
		"moduleResolution": "nodenext",
		"importHelpers": true,
		"experimentalDecorators": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"removeComments": true,
		// "noImplicitAny": false,
		"typeRoots": [
			"node_modules/@types",
		],
		"sourceMap": false,
		"baseUrl": "./",
		"paths": {
			"@azor.types/*": ["@types/*"],
			"@azor/*": ["src/*"],
			"@azor.server/*": ["server/*"],
			"@azor.lib/*": ["lib/*"],
			"@azor.ORM/*": ["src/lib/ORM/*"],
			"@azor.slash-commands/*": ["src/slash-commands/*"],
		}
	},
	"ts-node": {
		"files": true,
		"require": [
			"tsconfig-paths/register"
		]
	},
	"files": [
		"src/bot.ts"
	],
	"include": [
		"**/*.ts",
	],
	"exclude": [
		"node_modules",
		"dist"
	],
}