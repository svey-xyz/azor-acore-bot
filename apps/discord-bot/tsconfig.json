{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "./",
		"outDir": "./dist/",
		"baseUrl": "./",
		"typeRoots": [
			"./node_modules/@types",
			"../../node_modules/@types"
		],
		"paths": {
			"@azor.types/*": ["@types/*"],
			"@azor/*": ["src/*"],
			"@azor.lib/*": ["lib/*"],
			"@azor.slash-commands/*": ["src/slash-commands/*"]
		}
	},
	"ts-node": {
		"files": true,
		"require": [
			"tsconfig-paths/register"
		]
	},
	"files": [
		"src/bot.ts"
	],
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
