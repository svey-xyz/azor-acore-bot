# ---- Discord ------------------------------------------------------------
# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=
# Application ID (same page, under General Information)
DISCORD_CLIENT_ID=

# ---- AzerothCore SOAP (writes) -----------------------------------------
# Host/IP of the AzerothCore worldserver. On Docker, this is usually the
# service name of the worldserver container on the shared network.
SOAP_ENDPOINT=127.0.0.1
SOAP_PORT=7878
SOAP_USER=
SOAP_PASSWORD=

# ---- AzerothCore MySQL (reads) -----------------------------------------
# A read-only MySQL user is strongly recommended.
#
# Direct connection (default):
#   Set MYSQL_ENDPOINT to the host/IP where MySQL is reachable, e.g. the
#   AzerothCore server's LAN IP or Docker service name.
#
# SSH tunnel connection (SSH_TUNNEL_ENABLED=true):
#   MYSQL_ENDPOINT is ignored — the bot connects via SSH tunnel instead.
#   See the SSH Tunnel section below.
MYSQL_ENDPOINT=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# ---- SSH Tunnel (optional — replaces direct MySQL access) ---------------
# When SSH_TUNNEL_ENABLED=true the bot opens an SSH connection to SSH_HOST
# and forwards 127.0.0.1:SSH_TUNNEL_LOCAL_PORT → MYSQL_REMOTE_HOST:MYSQL_PORT
# on the remote machine. MySQL never needs to be reachable over the network.
#
# Server-side setup (one time):
#   1. Create a dedicated SSH user with no login shell:
#        useradd -r -s /usr/sbin/nologin discord-bot
#   2. Add the bot's public key with minimal authorized_keys options:
#        restrict,port-forwarding,permitopen="127.0.0.1:3306" ssh-ed25519 AAAA…
#      This disables everything except the specific MySQL port-forward.
#   3. Ensure MySQL is bound to 127.0.0.1 only (skip_networking or bind-address).
#
# Docker:
#   Drop your private key at ./config/ssh_key (chmod 600) and mount
#   ./config:/config:ro — see docker-compose.example.yml. The default
#   SSH_PRIVATE_KEY_PATH is /config/ssh_key so no override is needed.
#   MYSQL_ENDPOINT can be left as-is (it is ignored in tunnel mode).
#
SSH_TUNNEL_ENABLED=false
SSH_HOST=
SSH_PORT=22
SSH_USER=discord-bot
SSH_PRIVATE_KEY_PATH=/config/ssh_key
# MySQL host as seen from the SSH server (almost always 127.0.0.1)
MYSQL_REMOTE_HOST=127.0.0.1
# Free local port the tunnel binds to on the bot's machine
SSH_TUNNEL_LOCAL_PORT=13306

# ---- Behaviour ---------------------------------------------------------
# Non-secret feature/behaviour settings (gift item, cooldowns, announcement
# flags, enabled commands) live in config/azor.config.json — mount it at
# /config/azor.config.json. See that file for the full schema.
#
# Override the config file path:
# AZOR_CONFIG_PATH=/config/azor.config.json
#
# The legacy env-var overrides below still work and win over the JSON file
# (handy for one-off tweaks without rebuilding the config volume):
# TIP_ITEM_ID=
# GIFT_LEVEL_REQUIREMENT=
# GIFT_COOLDOWN=
# ANNOUNCE_COMMANDS_GLOBALLY=
# ANNOUNCE_COMMANDS_TO_PLAYERS=
# ENABLED_COMMANDS=
