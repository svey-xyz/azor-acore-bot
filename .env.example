# ---- Discord ------------------------------------------------------------
# Bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=
# Application ID (same page, under General Information)
DISCORD_CLIENT_ID=

# ---- AzerothCore SOAP (writes) -----------------------------------------
# Host/IP of the AzerothCore worldserver. On Docker, this is usually the
# service name of the worldserver container on the shared network.
SOAP_ENDPOINT=127.0.0.1
SOAP_PORT=7878
SOAP_USER=
SOAP_PASSWORD=

# ---- AzerothCore MySQL (reads) -----------------------------------------
# A read-only MySQL user is strongly recommended.
MYSQL_ENDPOINT=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# ---- Optional ----------------------------------------------------------
# Item entry sent by /character gift (default: 11966 - Small Sack of Coins)
TIP_ITEM_ID=11966
# Minimum recipient character level
GIFT_LEVEL_REQUIREMENT=10
# Cooldown between gifts, in milliseconds (default: 86400000 = 24h)
GIFT_COOLDOWN=86400000
# Broadcast command use to the whole server
ANNOUNCE_COMMANDS_GLOBALLY=true
# Whisper the targeted player when a command runs against them
ANNOUNCE_COMMANDS_TO_PLAYERS=true
# Comma-separated allow-list of enabled commands
ENABLED_COMMANDS=tip,character.info,character.location,character.status,realm.online,realm.pop
