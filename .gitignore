## Ignore build files, and cache files
dist/

## Ignore node dependencies
node_modules/
package-lock.json

## Ignore MacOS files.
.DS_Store
._*
._.*

.env.development
*.env
*.env.local
*.env.production

docker-compose.yml

## Never commit user-supplied SSH keys placed in the /config volume.
config/ssh_key
config/ssh_key.pub
config/*.pem
config/*.key
config/id_*